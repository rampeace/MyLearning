<Window x:Class="WpfPracticeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPracticeApp"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="640"
        Width="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#FFF7F7F7"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#26FFFFFF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCommandButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CommandBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CommandBorder" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CommandBorder" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="24"
                CornerRadius="28"
                BorderBrush="#1FFFFFFF"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EE090909" Offset="0"/>
                    <GradientStop Color="#E6141416" Offset="0.55"/>
                    <GradientStop Color="#D91C1C20" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="32"
                                  ShadowDepth="0"
                                  Color="#CC000000"
                                  Opacity="0.7"/>
            </Border.Effect>

            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="WPF Practice"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF8F8F8"/>
                        <TextBlock Text="Transparent near-black shell with a softer, polished layout."
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="#B8FFFFFF"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowCommandButtonStyle}"
                                Content="−"
                                Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource WindowCommandButtonStyle}"
                                Margin="8,0,0,0"
                                Content="✕"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border CornerRadius="22"
                            Background="#10FFFFFF"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            Padding="22">
                        <StackPanel>
                            <TextBlock Text="Launchers"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF4F4F4"/>
                            <TextBlock Text="Quick access to the sample windows in this project."
                                       Margin="0,6,0,22"
                                       TextWrapping="Wrap"
                                       Foreground="#B0FFFFFF"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open VSCode" Click="Button_Click"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Product Feedback" Click="Button_Click_1"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Contact Form" Click="Button_Click_2"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Button Control Template" Click="Button_Click_3"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Calculator" Click="Button_Click_4"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Person" Click="Button_Click_5"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Content="Open Custom Control" Click="Button_Click_6"/>
                            <Button Style="{StaticResource ActionButtonStyle}" Margin="0" Content="Community Toolkit MVVM" Click="Button_Click_7"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="22"
                            Background="#0CFFFFFF"
                            BorderBrush="#14FFFFFF"
                            BorderThickness="1"
                            Padding="30">
                        <Grid>
                            <Ellipse Width="260"
                                     Height="260"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,-90,-70,0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#2E8BFF" Offset="0"/>
                                        <GradientStop Color="#002E8BFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <StackPanel VerticalAlignment="Center" MaxWidth="420">
                                <TextBlock Text="Welcome to WPF"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           Foreground="#FFF8F8F8"/>
                                <TextBlock Text="The window now uses a transparent frame, near-black gradients, soft borders, and restrained highlights so the main screen feels cleaner without changing the rest of the project."
                                           Margin="0,14,0,0"
                                           TextWrapping="Wrap"
                                           FontSize="16"
                                           LineHeight="24"
                                           Foreground="#C8FFFFFF"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
